    <color name="badge_bg">#EBF5FB</color>
    <color name="bg_primary">#FFFFFF</color>
    <color name="bg_secondary">#F8F9FA</color>
    <color name="error">#e02424</color>
    <color name="primary">#1a56db</color>
    <color name="primary_dark">#1e429f</color>
    <color name="success">#057a55</color>
